# ---- Web Unlocker API configuration ----

# Remote Playwright browser server (separate container/service)
PLAYWRIGHT_SERVER_URL=ws://browser:3000/

# Redis connection string used for caching cleaned content
REDIS_URL=redis://redis:6379/0
CACHE_TTL_SECONDS=3600

# API key auth (choose ONE approach)
# Comma-separated SHA-256 hex digests of valid keys (recommended for prod):
API_KEY_HASHES=
# OR plain dev keys (hashed at startup) — local development only:
DEV_API_KEYS=changeme-dev-key

# Rate limiting (slowapi syntax) — per API key
REQUEST_RATE_LIMIT=5/minute

# OpenAI fallback for thin extractions (optional)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-3.5-turbo

# Proxy rotation: comma-separated proxy URLs OR a path to a file with one per line
FREE_PROXY_LIST=
MAX_PROXY_ATTEMPTS=3

# Browser navigation timeout (ms)
BROWSER_TIMEOUT_MS=15000
